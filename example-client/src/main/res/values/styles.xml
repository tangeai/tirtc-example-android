<resources>
    <style name="Theme.TiRtc.Example.Client" parent="Theme.Material3.Light.NoActionBar">
        <item name="colorPrimary">@color/demo_theme_primary</item>
        <item name="colorOnPrimary">@android:color/white</item>
        <item name="colorSurface">@color/demo_surface</item>
        <item name="android:statusBarColor">@color/demo_theme_primary</item>
        <item name="android:windowLightStatusBar">false</item>
    </style>

    <style name="TextAppearance.TiRtc.ToolbarTitle" parent="TextAppearance.Material3.TitleMedium">
        <item name="android:textColor">@android:color/white</item>
    </style>

    <style name="ThemeOverlay.TiRtc.TopAppBar" parent="ThemeOverlay.AppCompat.Dark.ActionBar">
        <item name="actionMenuTextColor">@android:color/white</item>
        <item name="colorControlNormal">@android:color/white</item>
    </style>

    <style name="Widget.TiRtc.TopAppBar" parent="Widget.Material3.Toolbar">
        <item name="android:background">@android:color/transparent</item>
        <item name="contentInsetStartWithNavigation">16dp</item>
        <item name="contentInsetStart">16dp</item>
        <item name="contentInsetEnd">4dp</item>
        <item name="contentInsetEndWithActions">4dp</item>
        <item name="navigationIconTint">@android:color/white</item>
        <item name="titleTextAppearance">@style/TextAppearance.TiRtc.ToolbarTitle</item>
        <item name="titleTextColor">@android:color/white</item>
        <item name="subtitleTextColor">@android:color/white</item>
    </style>

    <style name="Widget.TiRtc.TextInput" parent="Widget.Material3.TextInputLayout.OutlinedBox">
        <item name="boxStrokeColor">@color/demo_stroke</item>
        <item name="boxBackgroundColor">@color/demo_surface</item>
        <item name="hintTextColor">@color/demo_text_secondary</item>
    </style>

    <style name="ShapeAppearanceOverlay.TiRtc.VideoCard" parent="">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">16dp</item>
    </style>
</resources>
